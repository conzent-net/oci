{#
  Layout: Sidebar
  Full-height sidebar that slides in from the left or right.
  Logo at top, message in scrollable area, buttons fixed at bottom.
  Modern approach used by many premium CMPs.
#}
{% extends "gdpr/base.html.twig" %}

{% block banner %}
<div id="Conzent" tabindex="0" class="conzent-{{ banner_type }}{{ display_position }} cnz-sidebar">
  <div class="conzent-inner-content-box" style="background-color:{{ colors.notice_bg }}">
    <div class="conzent-notice">
      <p class="title-wrap" style="color:{{ colors.notice_title }}">{{ logo_html|raw }} [conzent_cookie_notice_banner_title]</p>

      <div class="cnz-sidebar-scroll">
        <div class="msg-wrap" style="color:{{ colors.notice_description }}">
          [conzent_cookie_notice_message]
          {{ privacy_policy_link|raw }}
        </div>
      </div>

      <div class="cnz-sidebar-footer" style="border-top:1px solid {{ colors.notice_border }}">
        <div class="btn-wrap">
          {{ buttons_html|raw }}
        </div>
        <div class="conzent-branding">
          {{ branding_html|raw }}
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
