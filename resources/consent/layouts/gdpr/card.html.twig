{#
  Layout: Card
  Centered card overlay with shadow — appears as a modal-like
  popup in the center of the screen. Logo centered above title,
  message centered, buttons in a row below. Premium feel.
#}
{% extends "gdpr/base.html.twig" %}

{% block banner %}
<div id="Conzent" tabindex="0" class="conzent-popup-center">
  <div class="conzent-inner-content-box" style="border:1px solid {{ colors.notice_border }};background-color:{{ colors.notice_bg }};text-align:center;max-width:520px;margin:auto;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
    <div class="conzent-notice">
      {% block banner_header %}
      <div style="text-align:center;margin-bottom:8px;">{{ logo_html|raw }}</div>
      <p class="title-wrap" style="color:{{ colors.notice_title }};justify-content:center;">[conzent_cookie_notice_banner_title]</p>
      {% endblock %}

      <div class="content-wrap" style="display:block;">
        <div class="msg-wrap" style="color:{{ colors.notice_description }};text-align:center;margin-bottom:16px;">
          [conzent_cookie_notice_message]
          {{ privacy_policy_link|raw }}
        </div>
        <div class="btn-wrap" style="justify-content:center;">
          {{ buttons_html|raw }}
        </div>
      </div>

      <div class="notice_button_wrap">{{ banner_cookie_list|raw }}{{ pref_buttons_html|raw }}</div>
      <div class="conzent-branding" style="display:flex;justify-content:center;padding:8px 0 0;font-size:11px;opacity:0.7;">
        {{ branding_html|raw }}
      </div>
    </div>
  </div>
</div>
{% endblock %}
