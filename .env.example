# Application
APP_ENV=production
APP_DEBUG=false
APP_SECRET=change-me-to-a-random-64-char-string
APP_URL=http://localhost:8100

# Database
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=oci
DB_USER=oci
DB_PASSWORD=oci
DATABASE_URL=mysql://oci:oci@mariadb:3306/oci?charset=utf8mb4

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Monetization
MONETIZATION_MODEL=oci

# Email (SMTP for notifications and password resets)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Conzent"

# CMP / IAB TCF
# CMP_ID: Your registered IAB CMP ID (validated against the IAB CMP registry).
# When set to a valid CMP ID, TCF v2.3 features are automatically enabled.
# Leave empty or set to 0 for Community Edition (no TCF/IAB features).
CMP_ID=

# OpenRouter (AI Translation)
# Get a key at https://openrouter.ai — used for auto-translating banner content.
# Leave empty to disable the Auto Translate button.
OPENROUTER_API_KEY=

# Google OAuth (used for "Sign in with Google" and GTM Wizard)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable "Tag Manager API" in APIs & Services → Library
# Set authorized redirect URIs:
#   {APP_URL}/auth/google/callback   (user login)
#   {APP_URL}/gtm/callback       (GTM wizard)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CDN (leave empty for local assets)
CDN_URL=

# Cloudflare (Edge cache purge on script regeneration)
# Get Zone ID from Cloudflare dashboard -> Overview -> API section
# Create API token at https://dash.cloudflare.com/profile/api-tokens with "Cache Purge" permission
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Scanning
SCAN_QUEUE_NAME=cookie_scans
SCAN_TIMEOUT=30

# Cache
# Set to true to disable all caching layers (browser, Redis, Cloudflare, minification).
DISABLE_CACHE=false

# Logging
LOG_LEVEL=warning
LOG_CHANNEL=stderr
