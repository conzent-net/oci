# Application
APP_ENV=production
APP_DEBUG=false
APP_SECRET=change-me-to-a-random-64-char-string
APP_URL=http://localhost

# Database
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=oci
DB_USER=oci
DB_PASSWORD=oci
DATABASE_URL=mysql://oci:oci@mariadb:3306/oci?charset=utf8mb4

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Monetization
MONETIZATION_MODEL=oci

# Email (SMTP for notifications and password resets)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Conzent"

# CMP / IAB TCF
CMP_ID=

# OpenRouter (AI Translation)
OPENROUTER_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CDN (leave empty for local assets)
CDN_URL=

# Cloudflare
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Scanning
SCAN_QUEUE_NAME=cookie_scans
SCAN_TIMEOUT=30

# Cache
DISABLE_CACHE=false

# Logging
LOG_LEVEL=warning
LOG_CHANNEL=stderr
