{% extends 'layouts/base.html.twig' %}
{% import 'components/macros.html.twig' as ui %}

{% block title %}Reports{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous" referrerpolicy="no-referrer" />
{% endblock %}

{% block content %}
<div x-data="reportsPage()">
    <nav class="breadcrumb mb-4" aria-label="breadcrumbs">
        <ul>
            <li><a href="/">Dashboard</a></li>
            <li class="is-active"><a>Reports</a></li>
        </ul>
    </nav>

    <div class="level mb-5">
        <div class="level-left">
            <h1 class="title is-3">Reports</h1>
        </div>
        <div class="level-right">
            <button class="button is-primary" @click="showGenerateModal = true">
                <span class="icon"><i class="fas fa-file-alt"></i></span>
                <span>Generate Report</span>
            </button>
        </div>
    </div>

    <div class="mb-4">
        {{ ui.siteSelector(sites, siteId, '/reports') }}
    </div>

    {# ── Schedule Config Card ──────────────────────────── #}
    <div class="box mb-5">
        <div class="level mb-3">
            <div class="level-left">
                <h2 class="subtitle is-5 mb-0">
                    <span class="icon"><i class="fas fa-clock"></i></span>
                    <span>Scheduled Reports</span>
                </h2>
            </div>
            <div class="level-right">
                <div class="field">
                    <label class="switch">
                        <input type="checkbox" x-model="schedule.is_active">
                        <span class="ml-2" x-text="schedule.is_active ? 'Enabled' : 'Disabled'"
                              :class="schedule.is_active ? 'has-text-success' : 'has-text-grey'"></span>
                    </label>
                </div>
            </div>
        </div>

        <div class="columns" x-show="schedule.is_active" x-transition>
            <div class="column is-4">
                <div class="field">
                    <label class="label is-small">Report Type</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select x-model="schedule.report_type">
                                <option value="full">Full Compliance</option>
                                <option value="consent">Consent Only</option>
                                <option value="scan">Cookie Scan Only</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="column is-4">
                <div class="field">
                    <label class="label is-small">Frequency</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select x-model="schedule.frequency">
                                <option value="monthly">Monthly (1st of month)</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="column is-4">
                <div class="field">
                    <label class="label is-small">Email Recipient</label>
                    <div class="control has-icons-left">
                        <input class="input" type="email" x-model="schedule.email_to" placeholder="email@example.com">
                        <span class="icon is-small is-left"><i class="fas fa-envelope"></i></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="has-text-right" x-show="schedule.is_active" x-transition>
            <button class="button is-small is-success" @click="saveSchedule()" :class="{'is-loading': savingSchedule}">
                <span class="icon"><i class="fas fa-save"></i></span>
                <span>Save Schedule</span>
            </button>
        </div>
    </div>

    {# ── Reports Table ────────────────────────────────── #}
    <div id="report-table-container">
        {% include 'pages/reports/_report_table.html.twig' %}
    </div>

    {# ── Generate Modal ───────────────────────────────── #}
    <div class="modal" :class="{'is-active': showGenerateModal}">
        <div class="modal-background" @click="showGenerateModal = false"></div>
        <div class="modal-card">
            <header class="modal-card-head">
                <p class="modal-card-title">Generate Report</p>
                <button class="delete" @click="showGenerateModal = false"></button>
            </header>
            <section class="modal-card-body">
                <div class="field">
                    <label class="label">Report Type</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select x-model="generateForm.report_type">
                                <option value="full">Full Compliance Report</option>
                                <option value="consent">Consent Report</option>
                                <option value="scan">Cookie Scan Report</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="field">
                    <label class="label">Date Range</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select x-model="generateForm.preset" @change="applyPreset()">
                                <option value="30days">Last 30 days</option>
                                <option value="last_month">Last month</option>
                                <option value="quarter">Last quarter</option>
                                <option value="custom">Custom range</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="columns" x-show="generateForm.preset === 'custom'" x-transition>
                    <div class="column">
                        <div class="field">
                            <label class="label is-small">Start Date</label>
                            <div class="control">
                                <input class="input" type="date" x-model="generateForm.period_start">
                            </div>
                        </div>
                    </div>
                    <div class="column">
                        <div class="field">
                            <label class="label is-small">End Date</label>
                            <div class="control">
                                <input class="input" type="date" x-model="generateForm.period_end">
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <footer class="modal-card-foot">
                <button class="button is-primary" @click="generateReport()" :class="{'is-loading': generating}">
                    <span class="icon"><i class="fas fa-cog"></i></span>
                    <span>Generate</span>
                </button>
                <button class="button" @click="showGenerateModal = false">Cancel</button>
            </footer>
        </div>
    </div>

    {# ── Send Modal ───────────────────────────────────── #}
    <div class="modal" :class="{'is-active': showSendModal}">
        <div class="modal-background" @click="showSendModal = false"></div>
        <div class="modal-card">
            <header class="modal-card-head">
                <p class="modal-card-title">Send Report via Email</p>
                <button class="delete" @click="showSendModal = false"></button>
            </header>
            <section class="modal-card-body">
                <div class="field">
                    <label class="label">Recipient Email</label>
                    <div class="control has-icons-left">
                        <input class="input" type="email" x-model="sendEmail" placeholder="email@example.com">
                        <span class="icon is-small is-left"><i class="fas fa-envelope"></i></span>
                    </div>
                    <p class="help">Leave blank to use the schedule email or your account email.</p>
                </div>
            </section>
            <footer class="modal-card-foot">
                <button class="button is-primary" @click="sendReport()" :class="{'is-loading': sending}">
                    <span class="icon"><i class="fas fa-paper-plane"></i></span>
                    <span>Send</span>
                </button>
                <button class="button" @click="showSendModal = false">Cancel</button>
            </footer>
        </div>
    </div>

    {# ── Delete Confirm Modal ─────────────────────────── #}
    <div class="modal" :class="{'is-active': showDeleteModal}">
        <div class="modal-background" @click="showDeleteModal = false"></div>
        <div class="modal-card">
            <header class="modal-card-head">
                <p class="modal-card-title">Delete Report</p>
                <button class="delete" @click="showDeleteModal = false"></button>
            </header>
            <section class="modal-card-body">
                <p>Are you sure you want to delete this report? This action cannot be undone.</p>
            </section>
            <footer class="modal-card-foot">
                <button class="button is-danger" @click="confirmDelete()" :class="{'is-loading': deleting}">Delete</button>
                <button class="button" @click="showDeleteModal = false">Cancel</button>
            </footer>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function reportsPage() {
    const today = new Date();
    const thirtyDaysAgo = new Date(today);
    thirtyDaysAgo.setDate(today.getDate() - 30);

    return {
        siteId: {{ siteId }},

        // Schedule
        schedule: {
            is_active: {{ schedule ? (schedule.is_active ? 'true' : 'false') : 'false' }},
            report_type: '{{ schedule.report_type ?? 'full' }}',
            frequency: '{{ schedule.frequency ?? 'monthly' }}',
            email_to: '{{ schedule.email_to ?? '' }}'
        },
        savingSchedule: false,

        // Generate modal
        showGenerateModal: false,
        generating: false,
        generateForm: {
            report_type: 'full',
            preset: '30days',
            period_start: thirtyDaysAgo.toISOString().split('T')[0],
            period_end: today.toISOString().split('T')[0]
        },

        // Send modal
        showSendModal: false,
        sending: false,
        sendReportId: null,
        sendEmail: '',

        // Delete modal
        showDeleteModal: false,
        deleting: false,
        deleteReportId: null,

        applyPreset() {
            const now = new Date();
            const end = new Date(now);

            switch (this.generateForm.preset) {
                case '30days':
                    const start30 = new Date(now);
                    start30.setDate(now.getDate() - 30);
                    this.generateForm.period_start = start30.toISOString().split('T')[0];
                    this.generateForm.period_end = end.toISOString().split('T')[0];
                    break;
                case 'last_month':
                    const firstLastMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1);
                    const lastLastMonth = new Date(now.getFullYear(), now.getMonth(), 0);
                    this.generateForm.period_start = firstLastMonth.toISOString().split('T')[0];
                    this.generateForm.period_end = lastLastMonth.toISOString().split('T')[0];
                    break;
                case 'quarter':
                    const start90 = new Date(now);
                    start90.setDate(now.getDate() - 90);
                    this.generateForm.period_start = start90.toISOString().split('T')[0];
                    this.generateForm.period_end = end.toISOString().split('T')[0];
                    break;
            }
        },

        async generateReport() {
            this.generating = true;
            try {
                const resp = await fetch('/app/reports/generate', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'Accept': 'application/json'},
                    body: JSON.stringify({
                        site_id: this.siteId,
                        report_type: this.generateForm.report_type,
                        period_start: this.generateForm.period_start,
                        period_end: this.generateForm.period_end
                    })
                });
                const data = await resp.json();
                if (data.success) {
                    this.showGenerateModal = false;
                    window.location.reload();
                } else {
                    alert(data.error?.message || 'Failed to generate report');
                }
            } catch (e) {
                alert('Error generating report');
            } finally {
                this.generating = false;
            }
        },

        async saveSchedule() {
            this.savingSchedule = true;
            try {
                const resp = await fetch('/app/reports/schedule', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'Accept': 'application/json'},
                    body: JSON.stringify({
                        site_id: this.siteId,
                        report_type: this.schedule.report_type,
                        frequency: this.schedule.frequency,
                        is_active: this.schedule.is_active ? 1 : 0,
                        email_to: this.schedule.email_to
                    })
                });
                const data = await resp.json();
                if (!data.success) {
                    alert(data.error?.message || 'Failed to save schedule');
                }
            } catch (e) {
                alert('Error saving schedule');
            } finally {
                this.savingSchedule = false;
            }
        },

        openSendModal(reportId) {
            this.sendReportId = reportId;
            this.sendEmail = this.schedule.email_to || '';
            this.showSendModal = true;
        },

        async sendReport() {
            this.sending = true;
            try {
                const resp = await fetch(`/app/reports/${this.sendReportId}/send`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'Accept': 'application/json'},
                    body: JSON.stringify({ email_to: this.sendEmail })
                });
                const data = await resp.json();
                if (data.success) {
                    this.showSendModal = false;
                    window.location.reload();
                } else {
                    alert(data.error?.message || 'Failed to send report');
                }
            } catch (e) {
                alert('Error sending report');
            } finally {
                this.sending = false;
            }
        },

        openDeleteModal(reportId) {
            this.deleteReportId = reportId;
            this.showDeleteModal = true;
        },

        async confirmDelete() {
            this.deleting = true;
            try {
                const resp = await fetch(`/app/reports/${this.deleteReportId}/delete`, {
                    method: 'POST',
                    headers: {'Accept': 'application/json'}
                });
                const data = await resp.json();
                if (data.success) {
                    this.showDeleteModal = false;
                    window.location.reload();
                } else {
                    alert(data.error?.message || 'Failed to delete report');
                }
            } catch (e) {
                alert('Error deleting report');
            } finally {
                this.deleting = false;
            }
        }
    };
}
</script>
{% endblock %}
