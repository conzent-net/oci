{% extends 'layouts/auth.html.twig' %}

{% block title %}Service Unavailable{% endblock %}

{% block content %}
<div class="auth-card" style="text-align:center; padding:3rem 2rem">
    <div style="font-size:3rem; margin-bottom:1rem">
        <span style="margin-right:0.25rem">&#127482;&#127462;</span>
    </div>

    <h2 class="title is-4" style="margin-bottom:0.75rem">We Stand With Ukraine</h2>

    <p style="color:#475569; font-size:0.95rem; line-height:1.7; margin-bottom:1.5rem">
        Due to the ongoing war against Ukraine, our services are not available
        in your region. We have made the decision not to provide our platform
        to organisations operating from the Russian Federation while the
        conflict continues.
    </p>

    <p style="color:#475569; font-size:0.95rem; line-height:1.7; margin-bottom:1.5rem">
        We understand that many individuals and businesses are caught in the
        middle of this situation through no fault of their own, and for that
        we are truly sorry.
    </p>

    <p style="color:#475569; font-size:0.95rem; line-height:1.7; margin-bottom:2rem">
        We hope for a peaceful resolution and look forward to the day we can
        serve everyone again.
    </p>

    <div style="border-top:1px solid #e2e8f0; padding-top:1.25rem; color:#94a3b8; font-size:0.8rem">
        <span style="color:#0057b8; font-weight:600">&#9632;</span>
        <span style="color:#ffd700; font-weight:600">&#9632;</span>
        &nbsp; Slava Ukraini
    </div>
</div>
{% endblock %}
