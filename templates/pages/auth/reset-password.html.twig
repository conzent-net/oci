{% extends 'layouts/auth.html.twig' %}

{% block title %}Reset Password{% endblock %}

{% block content %}
<div class="auth-card">
    <h2 class="title is-4 has-text-centered mb-5">Reset Password</h2>

    {% if invalid_token %}
        <div class="has-text-centered py-4">
            <span class="icon is-large has-text-danger">
                <i class="fas fa-link-slash fa-2x"></i>
            </span>
            <p class="mt-4 mb-2"><strong>Invalid or expired link</strong></p>
            <p style="color:#64748b;font-size:0.9rem">{{ error }}</p>
            <a href="/forgot-password" class="button is-primary is-fullwidth mt-5">Request New Link</a>
        </div>
    {% else %}
        {% if error %}
            <div class="notification is-danger is-light" style="border-radius:10px">
                <button class="delete" onclick="this.parentElement.remove()"></button>
                {{ error }}
            </div>
        {% endif %}

        <form method="post" action="/reset-password">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="token" value="{{ token }}">
            <input type="hidden" name="email" value="{{ email }}">

            <div class="field">
                <label class="label" for="password">New Password</label>
                <div class="control has-icons-left">
                    <input class="input" type="password" id="password" name="password"
                           placeholder="Minimum 8 characters" autocomplete="new-password" autofocus required minlength="8">
                    <span class="icon is-small is-left">
                        <i class="fas fa-lock"></i>
                    </span>
                </div>
            </div>

            <div class="field">
                <label class="label" for="password_confirm">Confirm Password</label>
                <div class="control has-icons-left">
                    <input class="input" type="password" id="password_confirm" name="password_confirm"
                           placeholder="Repeat your password" autocomplete="new-password" required minlength="8">
                    <span class="icon is-small is-left">
                        <i class="fas fa-lock"></i>
                    </span>
                </div>
            </div>

            <div class="field mt-5">
                <button class="button is-primary is-fullwidth" type="submit">
                    Reset Password
                </button>
            </div>
        </form>
    {% endif %}
</div>
{% endblock %}
