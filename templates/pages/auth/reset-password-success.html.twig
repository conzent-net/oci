{% extends 'layouts/auth.html.twig' %}

{% block title %}Password Reset{% endblock %}

{% block content %}
<div class="auth-card has-text-centered">
    <div class="py-4">
        <span class="icon is-large has-text-success">
            <i class="fas fa-circle-check fa-3x"></i>
        </span>

        <h2 class="title is-4 mt-4">Password updated</h2>
        <p style="color:#64748b;font-size:0.9rem" class="mb-5">Your password has been changed successfully. You can now log in with your new password.</p>

        <a href="/login" class="button is-primary is-fullwidth">
            Continue to Login
        </a>
    </div>
</div>
{% endblock %}
