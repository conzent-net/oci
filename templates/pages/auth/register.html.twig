{% extends 'layouts/auth.html.twig' %}

{% block title %}Create Account{% endblock %}

{% block content %}
<div class="auth-card">
    <h2 class="title is-4 has-text-centered mb-5">Create your account</h2>

    {% if error %}
        <div class="notification is-danger is-light" style="border-radius:10px">
            <button class="delete" onclick="this.parentElement.remove()"></button>
            {{ error }}
        </div>
    {% endif %}

    {# ── Google Sign-In ── #}
    {% if google_enabled is defined and google_enabled %}
    <a href="/auth/google" class="btn-google">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
    </a>

    <div class="auth-divider">or</div>
    {% endif %}

    {# ── Registration form ── #}
    <form method="post" action="/register">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <div class="columns is-mobile mb-0">
            <div class="column">
                <div class="field">
                    <label class="label" for="first_name">First Name</label>
                    <div class="control">
                        <input class="input" type="text" id="first_name" name="first_name"
                               value="{{ first_name }}" placeholder="John" autofocus>
                    </div>
                </div>
            </div>
            <div class="column">
                <div class="field">
                    <label class="label" for="last_name">Last Name</label>
                    <div class="control">
                        <input class="input" type="text" id="last_name" name="last_name"
                               value="{{ last_name }}" placeholder="Doe">
                    </div>
                </div>
            </div>
        </div>

        <div class="field">
            <label class="label" for="email">Email</label>
            <div class="control has-icons-left">
                <input class="input {{ errors.email is defined ? 'is-danger' : '' }}" type="email" id="email" name="email"
                       value="{{ email }}" placeholder="you@example.com"
                       autocomplete="email" required>
                <span class="icon is-small is-left">
                    <i class="fas fa-envelope"></i>
                </span>
            </div>
            {% if errors.email is defined %}
                <p class="help is-danger">{{ errors.email }}</p>
            {% endif %}
        </div>

        <div class="field">
            <label class="label" for="password">Password</label>
            <div class="control has-icons-left">
                <input class="input {{ errors.password is defined ? 'is-danger' : '' }}" type="password" id="password" name="password"
                       placeholder="At least 8 characters" autocomplete="new-password" required>
                <span class="icon is-small is-left">
                    <i class="fas fa-lock"></i>
                </span>
            </div>
            {% if errors.password is defined %}
                <p class="help is-danger">{{ errors.password }}</p>
            {% endif %}
        </div>

        <div class="field">
            <label class="label" for="password_confirm">Confirm Password</label>
            <div class="control has-icons-left">
                <input class="input {{ errors.password_confirm is defined ? 'is-danger' : '' }}" type="password" id="password_confirm" name="password_confirm"
                       placeholder="Repeat your password" autocomplete="new-password" required>
                <span class="icon is-small is-left">
                    <i class="fas fa-lock"></i>
                </span>
            </div>
            {% if errors.password_confirm is defined %}
                <p class="help is-danger">{{ errors.password_confirm }}</p>
            {% endif %}
        </div>

        <div class="field mt-5">
            <button class="button is-primary is-fullwidth" type="submit">
                Create Account
            </button>
        </div>
    </form>

    <p class="has-text-centered mt-4" style="font-size:0.85rem;color:#64748b">
        Already have an account? <a href="/login" style="color:#2e9e5e;font-weight:500">Log in</a>
    </p>
</div>
{% endblock %}
