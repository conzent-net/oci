{% extends 'layouts/auth.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block content %}
<div class="auth-card">
    <h2 class="title is-4 has-text-centered mb-2">Forgot password?</h2>

    {% if success %}
        <div class="has-text-centered py-4">
            <span class="icon is-large has-text-success">
                <i class="fas fa-paper-plane fa-2x"></i>
            </span>
            <p class="mt-4 mb-2"><strong>Check your email</strong></p>
            <p style="color:#64748b;font-size:0.9rem">If an account exists for that address, we've sent a password reset link. It expires in 60 minutes.</p>
            <a href="/login" class="button is-primary is-fullwidth mt-5">Back to Login</a>
        </div>
    {% else %}
        <p style="color:#64748b;font-size:0.9rem;text-align:center" class="mb-5">
            Enter your email and we'll send you a link to reset your password.
        </p>

        {% if error %}
            <div class="notification is-danger is-light" style="border-radius:10px">
                <button class="delete" onclick="this.parentElement.remove()"></button>
                {{ error }}
            </div>
        {% endif %}

        <form method="post" action="/forgot-password">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div class="field">
                <label class="label" for="email">Email Address</label>
                <div class="control has-icons-left">
                    <input class="input" type="email" id="email" name="email"
                           placeholder="you@example.com" autocomplete="email" autofocus required>
                    <span class="icon is-small is-left">
                        <i class="fas fa-envelope"></i>
                    </span>
                </div>
            </div>

            <div class="field mt-5">
                <button class="button is-primary is-fullwidth" type="submit">
                    Send Reset Link
                </button>
            </div>
        </form>

        <div class="has-text-centered mt-5">
            <a href="/login" style="font-size:0.85rem;color:#2e9e5e">
                <i class="fas fa-arrow-left" style="font-size:0.75rem;margin-right:0.25rem"></i>
                Back to Login
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
