{% extends 'layouts/base.html.twig' %}

{% set active_page = 'policies' %}

{% block title %}{{ title }}{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous" referrerpolicy="no-referrer" />
{% endblock %}

{% block content %}
<div x-data="cookiePolicyWizard()" x-init="init()">

    {% from 'components/macros.html.twig' import siteSelector, wizardSteps %}
    <nav class="breadcrumb mb-3" aria-label="breadcrumbs">
        <ul>
            <li><a href="/">Dashboard</a></li>
            <li><a href="/policies">Policies</a></li>
            <li class="is-active"><a href="#" aria-current="page">{{ templateId > 0 ? 'Edit Template' : 'Cookie Policy' }}</a></li>
        </ul>
    </nav>

    <div class="level mb-4">
        <div class="level-left">
            <div class="level-item">
                <h1 class="title is-4 mb-0">{{ templateId > 0 ? 'Edit Cookie Template' : 'Cookie Policy Wizard' }}</h1>
            </div>
            {% if templateId == 0 %}
            <div class="level-item">
                {{ siteSelector(sites, siteId, '/policies/cookie') }}
            </div>
            {% endif %}
        </div>
    </div>

    {% if templateId > 0 %}
    <div class="notification is-info is-light is-small mb-4" style="padding:0.75rem 1rem">
        <span class="icon"><i class="fas fa-layer-group"></i></span>
        Editing template: <strong>{{ templateName }}</strong>
        — Changes apply to the template only. Use "Apply to Sites" from the policies page to push to sites.
    </div>
    {% endif %}

    {# ── Step Indicator ─────────────────────────────────── #}
    {{ wizardSteps(['Types of Cookies', 'Manage Preferences', 'Preview'], 'step') }}

    {# ── Step 1: Types of Cookies ────────────────────── #}
    <div class="box" x-show="step === 1">
        <h2 class="subtitle is-6 mb-4">Types of Cookies</h2>

        <div class="field">
            <label class="label is-small">Type Heading</label>
            <div class="control">
                <input class="input is-small" type="text" x-model="form.type_heading">
            </div>
        </div>

        <div class="field">
            <label class="checkbox">
                <input type="checkbox" x-model="form.show_audit_table">
                Show cookie audit table in policy
            </label>
            <p class="help">When enabled, your scanned cookies will be displayed in the policy using <code>&lt;div class="cnz-cookie-table"&gt;&lt;/div&gt;</code></p>
        </div>

        <div class="field">
            <label class="checkbox">
                <input type="checkbox" x-model="form.show_heading">
                Include heading in generated policy
            </label>
            <p class="help">Disable this if embedding in a CMS that already provides its own page heading</p>
        </div>

        <div class="field mt-4">
            <button class="button is-primary is-small" @click="saveStep('cookie_types', 2)" :class="{ 'is-loading': saving }">
                Save &amp; Continue <span class="icon"><i class="fas fa-arrow-right"></i></span>
            </button>
        </div>
    </div>

    {# ── Step 2: Manage Preferences ──────────────────── #}
    <div class="box" x-show="step === 2">
        <h2 class="subtitle is-6 mb-4">Manage Cookie Preferences</h2>

        <div class="field">
            <label class="label is-small">Preference Heading</label>
            <div class="control">
                <input class="input is-small" type="text" x-model="form.preference_heading">
            </div>
        </div>

        <div class="field">
            <label class="label is-small">Revisit Consent Widget Code</label>
            <div class="control">
                <textarea class="textarea is-small" rows="2" x-model="form.revisit_consent_widget"></textarea>
            </div>
            <p class="help">HTML code for the "Cookie Settings" link, e.g. <code>&lt;a class="conzent-revisit"&gt;Cookie Settings&lt;/a&gt;</code></p>
        </div>

        <div class="field">
            <label class="label is-small">Preference Description</label>
            <div class="control">
                <textarea class="textarea is-small" rows="6" x-model="form.preference_description"></textarea>
            </div>
        </div>

        <div class="field">
            <label class="label is-small">Effective Date</label>
            <div class="control">
                <input class="input is-small" type="date" x-model="form.effective_date" style="max-width:200px">
            </div>
        </div>

        <div class="field mt-4">
            <div class="buttons">
                <button class="button is-small" @click="step = 1">
                    <span class="icon"><i class="fas fa-arrow-left"></i></span> <span>Back</span>
                </button>
                <button class="button is-primary is-small" @click="saveStep('preference', 3)" :class="{ 'is-loading': saving }">
                    Save &amp; Generate Preview <span class="icon"><i class="fas fa-arrow-right"></i></span>
                </button>
            </div>
        </div>
    </div>

    {# ── Step 3: Preview ─────────────────────────────── #}
    <div class="box" x-show="step === 3">
        <h2 class="subtitle is-6 mb-3">Preview</h2>

        <div class="buttons mb-3">
            <button class="button is-small is-info is-outlined" @click="copyHtml()">
                <span class="icon"><i class="fas fa-code"></i></span> <span>Copy HTML</span>
            </button>
            <button class="button is-small is-outlined" @click="copyText()">
                <span class="icon"><i class="fas fa-copy"></i></span> <span>Copy Text</span>
            </button>
        </div>

        <div class="content" style="border:1px solid var(--oci-border); border-radius:6px; padding:1.5rem; background:var(--oci-bg-alt);"
             x-html="previewHtml"></div>

        <div class="field mt-4">
            <div class="buttons">
                <button class="button is-small" @click="step = 2">
                    <span class="icon"><i class="fas fa-arrow-left"></i></span> <span>Back</span>
                </button>
                <a href="/policies" class="button is-primary is-small">
                    <span class="icon"><i class="fas fa-check"></i></span> <span>Done</span>
                </a>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
<script>
function cookiePolicyWizard() {
    var policyData = {{ policy|json_encode|raw }};
    var templateId = {{ templateId|default(0) }};
    return {
        step: 1,
        stepLabels: ['Types of Cookies', 'Manage Preferences', 'Preview'],
        saving: false,
        previewHtml: '',
        siteId: {{ siteId }},
        languageId: {{ languageId }},
        templateId: templateId,
        form: {
            type_heading: policyData.type_heading || 'Types of Cookies we use',
            show_audit_table: policyData.show_audit_table == 1,
            show_heading: policyData.show_heading != 0,
            preference_heading: policyData.preference_heading || 'Manage cookie preferences',
            revisit_consent_widget: policyData.revisit_consent_widget || '<a class="conzent-revisit">Cookie Settings</a>',
            preference_description: policyData.preference_description || '',
            effective_date: policyData.effective_date || new Date().toISOString().slice(0, 10)
        },

        init() {
            if (policyData.policy_content) {
                this.previewHtml = policyData.policy_content;
            }
        },

        saveStep(stepName, nextStep) {
            var self = this;
            self.saving = true;

            var body = Object.assign({}, self.form, {
                step: stepName
            });
            body.show_audit_table = self.form.show_audit_table ? 1 : 0;
            body.show_heading = self.form.show_heading ? 1 : 0;

            if (nextStep === 3) {
                body.step = 'preview';
            }

            // Include either template_id or site_id/language_id
            if (self.templateId > 0) {
                body.template_id = self.templateId;
            } else {
                body.site_id = self.siteId;
                body.language_id = self.languageId;
            }

            fetch('/app/policies/cookie/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(body)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success && data.data) {
                    if (data.data.content) {
                        self.previewHtml = data.data.content;
                    }
                    self.step = nextStep;
                }
            })
            .finally(function() { self.saving = false; });
        },

        copyHtml() {
            navigator.clipboard.writeText(this.previewHtml);
        },

        copyText() {
            var tmp = document.createElement('div');
            tmp.innerHTML = this.previewHtml;
            navigator.clipboard.writeText(tmp.textContent || tmp.innerText || '');
        }
    };
}
</script>
{% endblock %}
