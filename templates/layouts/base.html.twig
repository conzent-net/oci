<!DOCTYPE html>
<html lang="en" data-theme="light"
      x-data="{ sidebarOpen: window.innerWidth >= 1024, theme: localStorage.getItem('oci-theme') || 'light' }"
      x-init="$el.setAttribute('data-theme', theme)"
      @resize.window="if (window.innerWidth >= 1024) sidebarOpen = true">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Conzent{% endblock %} — Consent Management Platform</title>

    {# Inter font #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    {# Bulma CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css">

    {# Font Awesome (global — no need to include per page) #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />

    {# OCI custom styles #}
    <link rel="stylesheet" href="/assets/css/app.css?v=3">

    {# Alpine.js + htmx + marked.js (for notification markdown) #}
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    {% block head %}{% endblock %}
</head>
<body>

    {# Top navbar (3-column grid) #}
    {% block navbar %}
        {% include 'components/navbar.html.twig' %}
    {% endblock %}

    {# Layout wrapper #}
    <div class="oci-layout">
        {# Mobile overlay #}
        <div class="oci-overlay" x-show="sidebarOpen" x-transition.opacity
             @click="sidebarOpen = false" x-cloak></div>

        {# Sidebar #}
        <aside class="oci-sidebar" :class="{ 'is-open': sidebarOpen }" x-cloak>
            {% block sidebar %}
                {% include 'components/sidebar.html.twig' %}
            {% endblock %}
        </aside>

        {# Main content #}
        <main class="oci-main" id="main-content">
            {# Flash messages #}
            {% block flash %}
                {% if flash is defined and flash %}
                    {% for type, message in flash %}
                        <div class="notification is-{{ type }} is-light mb-4">
                            <button class="delete" onclick="this.parentElement.remove()"></button>
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endif %}
            {% endblock %}

            {# Page content #}
            {% block content %}{% endblock %}
        </main>
    </div>

    {# Footer (2-column grid matching sidebar) #}
    {% block footer %}
        {% include 'components/footer.html.twig' %}
    {% endblock %}

    {# Notification bell Alpine component #}
    <script>
    function notificationBell() {
        return {
            open: false,
            notifications: [],
            unreadCount: 0,
            modalOpen: false,
            modalTitle: '',
            modalBody: '',

            async load() {
                try {
                    const res = await fetch('/app/notifications');
                    const json = await res.json();
                    if (json.success) {
                        this.notifications = json.data.notifications;
                        this.unreadCount = json.data.unread_count;
                    }
                } catch (e) {
                    // silently fail — notifications are non-critical
                }
            },

            toggle() {
                this.open = !this.open;
            },

            async openNotification(n) {
                if (!n.is_read) {
                    fetch('/app/notifications/read', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ slug: n.slug }),
                    });
                    n.is_read = true;
                    this.unreadCount = Math.max(0, this.unreadCount - 1);
                }

                try {
                    const res = await fetch('/app/notifications/' + encodeURIComponent(n.slug));
                    const json = await res.json();
                    if (json.success) {
                        this.modalTitle = json.data.title;
                        this.modalBody = marked.parse(json.data.body);
                        this.modalOpen = true;
                        this.open = false;
                    }
                } catch (e) {
                    // fallback: show excerpt
                    this.modalTitle = n.title;
                    this.modalBody = '<p>' + n.excerpt + '</p>';
                    this.modalOpen = true;
                    this.open = false;
                }
            },

            async markAllRead() {
                try {
                    await fetch('/app/notifications/read-all', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                    });
                    this.notifications.forEach(n => n.is_read = true);
                    this.unreadCount = 0;
                } catch (e) {}
            }
        };
    }
    </script>

    {# Page-specific scripts #}
    {% block scripts %}{% endblock %}
</body>
</html>
