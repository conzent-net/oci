{# Revenue Impact Report — loaded via Alpine.js fetch from /app/ab-tests/{id}/impact #}

<div class="box mt-5" x-show="impactLoaded || impactLoading || impactError" x-cloak>
    <div class="level mb-4">
        <div class="level-left">
            <div class="level-item">
                <h2 class="title is-5 mb-0">
                    <span class="icon mr-2"><i class="fas fa-chart-line"></i></span>
                    Revenue Impact Analysis
                </h2>
            </div>
            <div class="level-item" x-show="impactLoaded">
                <span class="tag" :class="{
                    'is-warning is-light': impactData.tier === 'estimated',
                    'is-info is-light': impactData.tier === 'manual',
                    'is-success is-light': impactData.tier === 'live'
                }">
                    <span class="icon is-small mr-1">
                        <i class="fas" :class="{
                            'fa-calculator': impactData.tier === 'estimated',
                            'fa-sliders': impactData.tier === 'manual',
                            'fa-plug': impactData.tier === 'live'
                        }"></i>
                    </span>
                    <span x-text="impactData.tier === 'estimated' ? 'Estimated (Benchmarks)' : (impactData.tier === 'manual' ? 'Custom (Your Metrics)' : 'Live Data')"></span>
                </span>
            </div>
        </div>
        <div class="level-right">
            <div class="level-item" x-show="impactLoaded">
                <button class="button is-small is-light" @click="showSignalsModal = true">
                    <span class="icon"><i class="fas fa-sliders"></i></span>
                    <span>Business Metrics</span>
                </button>
            </div>
            <div class="level-item" x-show="impactLoaded">
                <a :href="'/app/ab-tests/{{ experiment.id }}/impact/export?format=csv'" class="button is-small is-light">
                    <span class="icon"><i class="fas fa-download"></i></span>
                    <span>Export CSV</span>
                </a>
            </div>
        </div>
    </div>

    {# Loading state #}
    <div x-show="impactLoading" class="has-text-centered py-5">
        <span class="icon is-large has-text-grey-light"><i class="fas fa-spinner fa-pulse fa-2x"></i></span>
        <p class="has-text-grey mt-2">Calculating revenue impact...</p>
    </div>

    {# Error state #}
    <div x-show="impactError" class="notification is-warning is-light" x-cloak>
        <span class="icon"><i class="fas fa-exclamation-triangle"></i></span>
        <span x-text="impactError"></span>
    </div>

    {# No data state #}
    <div x-show="impactLoaded && !impactError && (!impactData.variants || impactData.variants.length === 0)" class="has-text-centered py-5">
        <span class="icon is-large has-text-grey-light"><i class="fas fa-chart-bar fa-2x"></i></span>
        <p class="has-text-grey mt-2">No consent data yet. Start your experiment to collect data.</p>
    </div>

    {# Impact comparison table #}
    <div x-show="impactLoaded && impactData.variants && impactData.variants.length > 0">

        <div class="table-container">
            <table class="table is-fullwidth is-hoverable">
                <thead>
                    <tr>
                        <th>Metric</th>
                        <template x-for="v in impactData.variants" :key="v.variantId">
                            <th class="has-text-centered">
                                <span x-text="v.name"></span>
                                <span class="tag is-small ml-1" x-show="v.isControl" style="font-size:0.6rem">CONTROL</span>
                            </th>
                        </template>
                        <th class="has-text-centered" x-show="impactData.variants.length >= 2">Delta</th>
                    </tr>
                </thead>
                <tbody>
                    {# -- Consent Performance -- #}
                    <tr class="has-background-light">
                        <td colspan="99"><strong>Consent Performance</strong></td>
                    </tr>
                    <tr>
                        <td>Marketing Consent Rate</td>
                        <template x-for="v in impactData.variants" :key="'cr-'+v.variantId">
                            <td class="has-text-centered has-text-weight-semibold" x-text="(v.consentRate * 100).toFixed(1) + '%'"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaTag(impactData.comparison, 'consentRate', 'pp')"></td>
                    </tr>
                    <tr>
                        <td>Total Visitors</td>
                        <template x-for="v in impactData.variants" :key="'tv-'+v.variantId">
                            <td class="has-text-centered" x-text="v.totalVisitors.toLocaleString()"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2">—</td>
                    </tr>
                    <tr>
                        <td>Consented (Marketing)</td>
                        <template x-for="v in impactData.variants" :key="'cm-'+v.variantId">
                            <td class="has-text-centered" x-text="v.consentedVisitors.toLocaleString()"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaSimple(impactData.variants, 'consentedVisitors')"></td>
                    </tr>

                    {# -- Google Ads Impact -- #}
                    <tr class="has-background-light">
                        <td colspan="99">
                            <strong><i class="fab fa-google mr-1"></i> Google Ads Impact</strong>
                            <span class="tag is-small ml-2" :class="tierBadgeClass(impactData.variants[0]?.tierDetails?.google)"
                                  x-text="tierLabel(impactData.variants[0]?.tierDetails?.google)"></span>
                        </td>
                    </tr>
                    <tr>
                        <td>Conversion Signals (Observed)</td>
                        <template x-for="v in impactData.variants" :key="'goc-'+v.variantId">
                            <td class="has-text-centered" x-text="v.google.observedConversions.toLocaleString()"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaPercent(impactData.comparison, 'googleConversions')"></td>
                    </tr>
                    <tr>
                        <td>Modeled Conversions</td>
                        <template x-for="v in impactData.variants" :key="'gmc-'+v.variantId">
                            <td class="has-text-centered" x-text="'~' + v.google.modeledConversions.toLocaleString()"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2">—</td>
                    </tr>
                    <tr>
                        <td>Total Conversions</td>
                        <template x-for="v in impactData.variants" :key="'gtc-'+v.variantId">
                            <td class="has-text-centered has-text-weight-semibold" x-text="'~' + v.google.totalConversions.toLocaleString()"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaPercent(impactData.comparison, 'googleConversions')"></td>
                    </tr>
                    <tr>
                        <td>Signal Quality</td>
                        <template x-for="v in impactData.variants" :key="'gsq-'+v.variantId">
                            <td class="has-text-centered" x-text="Math.round(v.google.signalQualityScore * 100) + '%'"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaTag(impactData.comparison, 'googleSignalQuality', 'pp')"></td>
                    </tr>
                    <tr>
                        <td>Est. Revenue</td>
                        <template x-for="v in impactData.variants" :key="'grev-'+v.variantId">
                            <td class="has-text-centered has-text-weight-semibold"
                                :style="v.tierDetails?.google !== 'live' ? 'border-style:dashed' : ''"
                                x-text="'€' + v.google.estimatedRevenue.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0})"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaRevenue(impactData.comparison, 'googleRevenue')"></td>
                    </tr>
                    <tr>
                        <td>Modeling Eligible</td>
                        <template x-for="v in impactData.variants" :key="'gme-'+v.variantId">
                            <td class="has-text-centered">
                                <span class="icon" :class="v.google.modelingEligible ? 'has-text-success' : 'has-text-danger'">
                                    <i class="fas" :class="v.google.modelingEligible ? 'fa-check-circle' : 'fa-times-circle'"></i>
                                </span>
                            </td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2">—</td>
                    </tr>

                    {# -- Meta Ads Impact -- #}
                    <tr class="has-background-light">
                        <td colspan="99">
                            <strong><i class="fab fa-meta mr-1"></i> Meta Ads Impact</strong>
                            <span class="tag is-small ml-2" :class="tierBadgeClass(impactData.variants[0]?.tierDetails?.meta)"
                                  x-text="tierLabel(impactData.variants[0]?.tierDetails?.meta)"></span>
                        </td>
                    </tr>
                    <tr>
                        <td>Pixel Fire Rate</td>
                        <template x-for="v in impactData.variants" :key="'mpfr-'+v.variantId">
                            <td class="has-text-centered" x-text="(v.meta.pixelFireRate * 100).toFixed(1) + '%'"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaTag(impactData.comparison, 'metaPixelFireRate', 'pp')"></td>
                    </tr>
                    <tr>
                        <td>Est. Event Match Quality</td>
                        <template x-for="v in impactData.variants" :key="'memq-'+v.variantId">
                            <td class="has-text-centered" x-text="v.meta.estimatedEMQ + ' / 10'"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaTag(impactData.comparison, 'metaEMQ', 'pts')"></td>
                    </tr>
                    <tr>
                        <td>Signal Loss</td>
                        <template x-for="v in impactData.variants" :key="'msl-'+v.variantId">
                            <td class="has-text-centered" x-text="v.meta.signalLossPercent + '%'"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaTag(impactData.comparison, 'metaSignalLoss', 'pp', true)"></td>
                    </tr>
                    <tr>
                        <td>Visible Conversions</td>
                        <template x-for="v in impactData.variants" :key="'mvc-'+v.variantId">
                            <td class="has-text-centered" x-text="'~' + v.meta.visibleConversions.toLocaleString()"></td>
                        </template>
                        <td class="has-text-centered" x-show="impactData.variants.length >= 2"
                            x-html="deltaPercent(impactData.comparison, 'metaConversions')"></td>
                    </tr>
                </tbody>
            </table>
        </div>

        {# -- Recommendation Box -- #}
        <div class="notification is-success is-light mt-4" x-show="impactData.recommendation" x-cloak>
            <div class="columns is-vcentered">
                <div class="column">
                    <p class="title is-6 mb-1">
                        <i class="fas fa-trophy mr-1"></i> Recommendation
                    </p>
                    <p x-text="impactData.recommendation?.summary"></p>
                </div>
                <div class="column is-narrow">
                    <div class="tags">
                        <span class="tag is-success is-medium" x-show="impactData.recommendation?.revenueGain > 0">
                            +€<span x-text="impactData.recommendation?.revenueGain?.toLocaleString(undefined, {maximumFractionDigits:0})"></span>/mo
                        </span>
                        <span class="tag is-info is-medium" x-show="impactData.recommendation?.consentRateGain > 0">
                            +<span x-text="impactData.recommendation?.consentRateGain"></span>pp consent
                        </span>
                    </div>
                </div>
            </div>
        </div>

        {# -- Platform Connection CTAs -- #}
        <div class="columns mt-4">
            <div class="column">
                <div class="box has-text-centered py-4" style="border:2px dashed var(--oci-border)">
                    <span class="icon has-text-grey-light"><i class="fab fa-google fa-2x"></i></span>
                    <p class="has-text-weight-semibold mt-2">Connect Google Ads</p>
                    <p class="is-size-7 has-text-grey">Replace estimates with real ROAS, CPA, and conversion data</p>
                    <button class="button is-small is-light mt-2" disabled>
                        <span class="icon"><i class="fas fa-plug"></i></span>
                        <span>Coming Soon</span>
                    </button>
                </div>
            </div>
            <div class="column">
                <div class="box has-text-centered py-4" style="border:2px dashed var(--oci-border)">
                    <span class="icon has-text-grey-light"><i class="fab fa-meta fa-2x"></i></span>
                    <p class="has-text-weight-semibold mt-2">Connect Meta Ads</p>
                    <p class="is-size-7 has-text-grey">Get real EMQ scores, ROAS, and conversion attribution</p>
                    <button class="button is-small is-light mt-2" disabled>
                        <span class="icon"><i class="fas fa-plug"></i></span>
                        <span>Coming Soon</span>
                    </button>
                </div>
            </div>
        </div>

        {# -- How We Calculated This -- #}
        <details class="mt-3">
            <summary class="is-size-7 has-text-grey" style="cursor:pointer">
                <i class="fas fa-info-circle mr-1"></i> How we calculated this
            </summary>
            <div class="content is-small mt-2 ml-4" style="max-width:640px">
                <p><strong>Google Ads:</strong> Consented visitors send full conversion signals. Denied visitors send cookieless pings
                   via Advanced Consent Mode, and Google's AI recovers ~65% of missed conversions through modeling.
                   Higher consent rates improve Smart Bidding signal quality (rated 0-100%).</p>
                <p><strong>Meta Ads:</strong> Meta Pixel only fires for consented users (binary consent).
                   Event Match Quality (EMQ 0-10) improves with more pixel data.
                   Signal loss = percentage of visitors Meta cannot track.</p>
                <p><strong>Revenue estimates</strong> use industry benchmarks (3.5% conversion rate, €85 avg order value).
                   <a href="#" @click.prevent="showSignalsModal = true">Enter your own metrics</a> for more accurate projections.</p>
            </div>
        </details>
    </div>
</div>

{# ── Business Metrics Modal (Tier 2 Signals) ──────────────────── #}
<div class="modal" :class="{ 'is-active': showSignalsModal }">
    <div class="modal-background" @click="showSignalsModal = false"></div>
    <div class="modal-card" style="max-width:560px">
        <header class="modal-card-head">
            <p class="modal-card-title is-size-6">
                <i class="fas fa-sliders mr-1"></i> Business Metrics
            </p>
            <button class="delete" aria-label="close" @click="showSignalsModal = false"></button>
        </header>
        <section class="modal-card-body">
            <p class="is-size-7 has-text-grey mb-4">
                Enter your actual business metrics for more accurate revenue projections.
                These replace industry benchmark estimates.
            </p>

            {# Industry Preset #}
            <div class="field">
                <label class="label is-small">Industry Preset</label>
                <div class="select is-fullwidth">
                    <select x-model="signals.industryVertical" @change="applyPreset()">
                        <option value="">Select your industry...</option>
                        <template x-for="(preset, key) in industryPresets" :key="key">
                            <option :value="key" x-text="preset.label"></option>
                        </template>
                    </select>
                </div>
                <p class="help">Pre-fills fields with industry averages</p>
            </div>

            <hr class="my-3">

            <div class="columns is-multiline">
                <div class="column is-half">
                    <div class="field">
                        <label class="label is-small">Google Ads Monthly Spend (€)</label>
                        <input class="input is-small" type="number" step="0.01" x-model="signals.googleAdsMonthlySpend" placeholder="e.g. 5000">
                    </div>
                </div>
                <div class="column is-half">
                    <div class="field">
                        <label class="label is-small">Meta Ads Monthly Spend (€)</label>
                        <input class="input is-small" type="number" step="0.01" x-model="signals.metaAdsMonthlySpend" placeholder="e.g. 3000">
                    </div>
                </div>
                <div class="column is-half">
                    <div class="field">
                        <label class="label is-small">Avg. CPC (€)</label>
                        <input class="input is-small" type="number" step="0.01" x-model="signals.avgCPC" placeholder="1.50">
                    </div>
                </div>
                <div class="column is-half">
                    <div class="field">
                        <label class="label is-small">Avg. Conversion Rate (%)</label>
                        <input class="input is-small" type="number" step="0.1" x-model="signals.avgConversionRate" placeholder="3.5">
                    </div>
                </div>
                <div class="column is-half">
                    <div class="field">
                        <label class="label is-small">Avg. Order Value (€)</label>
                        <input class="input is-small" type="number" step="0.01" x-model="signals.avgOrderValue" placeholder="85">
                    </div>
                </div>
                <div class="column is-half">
                    <div class="field">
                        <label class="label is-small">Current Consent Rate (%)</label>
                        <input class="input is-small" type="number" step="0.1" x-model="signals.currentConsentRate" placeholder="31">
                    </div>
                </div>
            </div>

            <details class="mt-2">
                <summary class="is-size-7 has-text-grey" style="cursor:pointer">Advanced Google Ads settings</summary>
                <div class="columns is-multiline mt-1">
                    <div class="column is-half">
                        <div class="field">
                            <label class="label is-small">Google Conversion Value (€)</label>
                            <input class="input is-small" type="number" step="0.01" x-model="signals.googleConversionValue">
                        </div>
                    </div>
                    <div class="column is-half">
                        <div class="field">
                            <label class="label is-small">Target ROAS</label>
                            <input class="input is-small" type="number" step="0.1" x-model="signals.googleTargetROAS" placeholder="4.0">
                        </div>
                    </div>
                    <div class="column is-half">
                        <div class="field">
                            <label class="label is-small">Weekly Ad Clicks</label>
                            <input class="input is-small" type="number" x-model="signals.weeklyAdClicks">
                        </div>
                    </div>
                </div>
            </details>

            <details class="mt-2">
                <summary class="is-size-7 has-text-grey" style="cursor:pointer">Advanced Meta Ads settings</summary>
                <div class="columns is-multiline mt-1">
                    <div class="column is-half">
                        <div class="field">
                            <label class="label is-small">Current EMQ Score (0-10)</label>
                            <input class="input is-small" type="number" step="0.1" min="0" max="10" x-model="signals.metaCurrentEMQ">
                        </div>
                    </div>
                    <div class="column is-half">
                        <div class="field">
                            <label class="label is-small">Meta Cost Per Result (€)</label>
                            <input class="input is-small" type="number" step="0.01" x-model="signals.metaCostPerResult">
                        </div>
                    </div>
                </div>
            </details>

            <p class="has-text-danger is-size-7 mt-2" x-show="signalsError" x-text="signalsError"></p>
        </section>
        <footer class="modal-card-foot">
            <button class="button is-success" @click="saveSignals()" :class="{ 'is-loading': signalsSaving }">
                <span class="icon"><i class="fas fa-check"></i></span>
                <span>Save & Recalculate</span>
            </button>
            <button class="button" @click="showSignalsModal = false">Cancel</button>
        </footer>
    </div>
</div>
